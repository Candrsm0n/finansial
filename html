<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title>Aplikasi Keuangan Pribadi Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background: #f0f2f8; overflow-x: hidden; }
        
        /* LOGIN PAGE */
        .login-page { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .login-card { background: white; border-radius: 32px; box-shadow: 0 25px 50px rgba(0,0,0,0.25); width: 480px; max-width: 100%; overflow: hidden; }
        .login-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 30px; text-align: center; color: white; }
        .login-header h2 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
        .login-header p { font-size: 14px; opacity: 0.9; }
        .login-body { padding: 32px; }
        .login-title { font-size: 24px; font-weight: 700; color: #1a1a2e; margin-bottom: 8px; }
        .login-subtitle { font-size: 14px; color: #666; margin-bottom: 28px; }
        
        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 14px; font-weight: 600; color: #333; margin-bottom: 8px; }
        .input-icon { position: relative; }
        .input-icon i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 16px; }
        .form-control { width: 100%; padding: 14px 15px 14px 45px; border: 2px solid #e0e0e0; border-radius: 14px; font-size: 15px; transition: all 0.3s; background: #f8f9fa; }
        .form-control:focus { border-color: #667eea; outline: none; background: white; box-shadow: 0 0 0 3px rgba(102,126,234,0.2); }
        
        .form-options { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 10px; }
        .checkbox-label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; color: #555; }
        .checkbox-label input { width: 18px; height: 18px; cursor: pointer; accent-color: #667eea; }
        .forgot-link { color: #667eea; text-decoration: none; font-size: 14px; font-weight: 500; cursor: pointer; }
        .forgot-link:hover { text-decoration: underline; }
        
        .btn-signin { width: 100%; padding: 14px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 14px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.3s; margin-bottom: 20px; }
        .btn-signin:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(102,126,234,0.4); }
        .register-link { text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid #e0e0e0; }
        .register-link p { font-size: 14px; color: #666; }
        .register-link a { color: #667eea; text-decoration: none; font-weight: 600; cursor: pointer; }
        
        .alert { padding: 12px 15px; border-radius: 12px; margin-bottom: 20px; font-size: 13px; display: none; }
        .alert-danger { background: #fee2e2; color: #dc2626; border-left: 4px solid #dc2626; }
        .alert-success { background: #dcfce7; color: #16a34a; border-left: 4px solid #16a34a; }
        .alert-info { background: #dbeafe; color: #2563eb; border-left: 4px solid #2563eb; }
        
        /* SIDEBAR */
        .sidebar { min-height: 100vh; background: linear-gradient(180deg, #1a2a3a, #0f2027); position: fixed; top: 0; left: 0; width: 280px; color: white; z-index: 1000; transition: transform 0.3s ease-in-out; overflow-y: auto; transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .sidebar-header { padding: 30px 20px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header i { font-size: 50px; margin-bottom: 10px; }
        .sidebar-header h5 { font-size: 20px; font-weight: 600; }
        .sidebar-menu { padding: 20px 0; }
        .sidebar-menu button { display: block; width: 100%; padding: 15px 25px; background: none; border: none; color: rgba(255,255,255,0.8); text-align: left; font-size: 15px; cursor: pointer; transition: 0.3s; border-left: 4px solid transparent; }
        .sidebar-menu button:hover { background: rgba(255,255,255,0.15); color: white; border-left-color: #667eea; padding-left: 35px; }
        .sidebar-menu button.active { background: rgba(255,255,255,0.2); color: white; border-left-color: #667eea; }
        .sidebar-menu i { width: 25px; margin-right: 10px; }
        
        .sidebar-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; display: none; cursor: pointer; }
        .sidebar-overlay.active { display: block; }
        
        .content { margin-left: 0; padding: 20px; transition: margin-left 0.3s; min-height: 100vh; }
        .header { background: white; border-radius: 20px; padding: 20px; margin-bottom: 20px; box-shadow: 0 8px 20px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; }
        .header h3 { margin: 0; background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 700; }
        .date { background: linear-gradient(135deg, #f8f9fa, #e9ecef); padding: 8px 18px; border-radius: 30px; font-size: 14px; color: #555; }
        
        .card { background: white; border-radius: 20px; box-shadow: 0 8px 25px rgba(0,0,0,0.05); margin-bottom: 20px; border: none; overflow: hidden; }
        .card-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 15px 20px; }
        .card-body { padding: 20px; }
        
        .btn { padding: 10px 20px; border: none; border-radius: 12px; cursor: pointer; font-weight: 600; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-primary { background: linear-gradient(135deg, #667eea, #764ba2); color: white; }
        .btn-success { background: #28a745; color: white; }
        .btn-danger { background: #dc3545; color: white; }
        .btn-warning { background: #ffc107; color: #333; }
        .btn-sm { padding: 6px 14px; font-size: 12px; border-radius: 8px; }
        
        .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 20px; }
        .stat-card { background: white; border-radius: 20px; padding: 18px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); display: flex; align-items: center; gap: 15px; }
        .stat-icon { width: 55px; height: 55px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .stat-icon.primary { background: rgba(102,126,234,0.15); color: #667eea; }
        .stat-icon.success { background: rgba(40,167,69,0.15); color: #28a745; }
        .stat-icon.danger { background: rgba(220,53,69,0.15); color: #dc3545; }
        .stat-icon.info { background: rgba(23,162,184,0.15); color: #17a2b8; }
        .stat-info h6 { font-size: 11px; color: #888; margin-bottom: 5px; text-transform: uppercase; }
        .stat-info h4 { font-size: 20px; font-weight: 800; margin: 0; color: #2c3e50; }
        
        .ringkasan-card { background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 20px; padding: 20px; color: white; height: 100%; }
        .ringkasan-item { background: rgba(255,255,255,0.15); border-radius: 14px; padding: 15px; margin-bottom: 12px; }
        .ringkasan-item h5 { font-size: 24px; font-weight: 800; margin: 5px 0 0 0; }
        .ringkasan-item p { margin: 0; opacity: 0.9; font-size: 12px; }
        
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 500px; }
        th { background: #f8f9fa; padding: 12px; text-align: left; font-weight: 700; border-bottom: 2px solid #667eea; }
        td { padding: 12px; border-bottom: 1px solid #e0e0e0; }
        .badge { padding: 5px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; display: inline-block; }
        .badge-success { background: #28a745; color: white; }
        .badge-danger { background: #dc3545; color: white; }
        
        .form-group { margin-bottom: 15px; }
        .form-label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 14px; }
        .form-control, .form-select { width: 100%; padding: 12px 15px; border: 2px solid #e0e0e0; border-radius: 12px; font-size: 14px; }
        .form-control:focus, .form-select:focus { border-color: #667eea; outline: none; box-shadow: 0 0 0 3px rgba(102,126,234,0.2); }
        
        .tabs { display: flex; gap: 5px; margin-bottom: 20px; border-bottom: 2px solid #e0e0e0; flex-wrap: wrap; }
        .tab-btn { background: none; border: none; padding: 10px 20px; font-size: 14px; font-weight: 600; color: #7f8c8d; cursor: pointer; border-bottom: 3px solid transparent; }
        .tab-btn.active { color: #667eea; border-bottom-color: #667eea; }
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }
        
        .row { display: flex; flex-wrap: wrap; margin: 0 -10px; }
        .col-md-6 { width: 100%; padding: 0 10px; margin-bottom: 15px; }
        .col-md-4 { width: 100%; padding: 0 10px; margin-bottom: 15px; }
        .col-md-8 { width: 100%; padding: 0 10px; margin-bottom: 15px; }
        .d-flex { display: flex; }
        .justify-content-between { justify-content: space-between; }
        .flex-wrap { flex-wrap: wrap; }
        .gap-2 { gap: 10px; }
        .text-success { color: #28a745 !important; }
        .text-danger { color: #dc3545 !important; }
        .text-center { text-align: center; }
        .text-end { text-align: right; }
        .fw-bold { font-weight: 700; }
        .mb-2 { margin-bottom: 10px; }
        .mb-3 { margin-bottom: 15px; }
        .mb-4 { margin-bottom: 20px; }
        .mt-2 { margin-top: 10px; }
        .w-100 { width: 100%; }
        .chart-container { position: relative; height: 250px; width: 100%; }
        
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; }
        .modal-content { background: white; border-radius: 20px; width: 90%; max-width: 500px; max-height: 80vh; overflow-y: auto; margin: auto; }
        .modal-header { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 15px 20px; border-radius: 20px 20px 0 0; display: flex; justify-content: space-between; align-items: center; }
        .modal-body { padding: 20px; }
        .modal-footer { padding: 15px 20px; border-top: 1px solid #e0e0e0; display: flex; justify-content: flex-end; gap: 10px; }
        .close-btn { background: none; border: none; color: white; font-size: 24px; cursor: pointer; }
        
        .category-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid #e0e0e0; }
        .category-badge { width: 20px; height: 20px; border-radius: 6px; margin-right: 10px; display: inline-block; }
        
        .progress { height: 20px; background: #f0f0f0; border-radius: 10px; overflow: hidden; margin: 10px 0; }
        .progress-bar { height: 100%; background: linear-gradient(90deg, #28a745, #20c997); color: white; display: flex; align-items: center; justify-content: center; font-size: 11px; }
        
        .menu-toggle { position: fixed; bottom: 20px; right: 20px; z-index: 1001; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 50%; width: 55px; height: 55px; font-size: 24px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; }
        
        .export-preview { background: #1e1e2f; border-radius: 12px; padding: 15px; margin-top: 15px; overflow-x: auto; }
        .csv-preview-table { width: 100%; font-size: 11px; border-collapse: collapse; }
        .csv-preview-table th { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 8px; text-align: center; }
        .csv-preview-table td { padding: 6px 8px; border-bottom: 1px solid #334; color: #ddd; text-align: center; }
        
        @media (min-width: 768px) {
            .content { margin-left: 280px; padding: 30px; }
            .col-md-6 { width: 50%; margin-bottom: 0; }
            .col-md-4 { width: 33.33%; margin-bottom: 0; }
            .col-md-8 { width: 66.67%; margin-bottom: 0; }
            .stat-card { padding: 22px; }
            .stat-icon { width: 65px; height: 65px; font-size: 28px; }
            .stat-info h4 { font-size: 26px; }
            .menu-toggle { display: none; }
            .sidebar { transform: translateX(0) !important; }
        }
        
        @media (max-width: 767px) {
            .stat-row { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .stat-card { padding: 12px; }
            .stat-icon { width: 45px; height: 45px; font-size: 20px; }
            .stat-info h4 { font-size: 16px; }
            .ringkasan-item h5 { font-size: 20px; }
            .btn { padding: 8px 16px; font-size: 13px; }
        }
        @media (max-width: 480px) {
            .stat-row { grid-template-columns: 1fr; }
            .content { padding: 15px; }
        }
    </style>
</head>
<body>
    <!-- LOGIN PAGE -->
    <div id="loginPage" class="login-page">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-wallet fa-3x mb-2"></i>
                <h2>Keuangan Pro</h2>
                <p>Kelola Keuangan Pribadi dengan Mudah</p>
            </div>
            <div class="login-body">
                <div id="loginFormDiv">
                    <div class="login-title">Sign In</div>
                    <div class="login-subtitle">Masukkan email/phone dan password untuk login</div>
                    <div id="loginError" class="alert alert-danger"></div>
                    <form id="loginForm">
                        <div class="form-group">
                            <label class="form-label">Email / Phone</label>
                            <div class="input-icon">
                                <i class="fas fa-envelope"></i>
                                <input type="text" id="username" class="form-control" placeholder="admin@example.com atau admin">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Password</label>
                            <div class="input-icon">
                                <i class="fas fa-lock"></i>
                                <input type="password" id="password" class="form-control" placeholder="Masukkan password">
                            </div>
                        </div>
                        <div class="form-options">
                            <label class="checkbox-label">
                                <input type="checkbox" id="rememberMe">
                                <span>Remember me</span>
                            </label>
                            <a class="forgot-link" onclick="showForgotPassword()">Lupa Password?</a>
                        </div>
                        <button type="submit" class="btn-signin"><i class="fas fa-arrow-right-to-bracket me-2"></i>Sign In</button>
                    </form>
                    <div class="register-link">
                        <p>Don't have an account? <a onclick="showRegisterForm()">Register</a></p>
                    </div>
                </div>
                <div id="registerFormDiv" style="display: none;">
                    <div class="login-title">Create Account</div>
                    <div class="login-subtitle">Daftar akun baru untuk memulai</div>
                    <div id="registerError" class="alert alert-danger"></div>
                    <div id="registerSuccess" class="alert alert-success"></div>
                    <form>
                        <div class="form-group"><label class="form-label">Username</label><div class="input-icon"><i class="fas fa-user"></i><input type="text" id="regUsername" class="form-control" placeholder="Buat username"></div></div>
                        <div class="form-group"><label class="form-label">Email / Phone</label><div class="input-icon"><i class="fas fa-envelope"></i><input type="text" id="regEmail" class="form-control" placeholder="email@example.com"></div></div>
                        <div class="form-group"><label class="form-label">Password</label><div class="input-icon"><i class="fas fa-lock"></i><input type="password" id="regPassword" class="form-control" placeholder="Buat password"></div></div>
                        <div class="form-group"><label class="form-label">Confirm Password</label><div class="input-icon"><i class="fas fa-check-circle"></i><input type="password" id="regConfirmPassword" class="form-control" placeholder="Konfirmasi password"></div></div>
                        <button type="button" onclick="registerUser()" class="btn-signin"><i class="fas fa-user-plus me-2"></i>Register</button>
                    </form>
                    <div class="register-link"><p>Already have an account? <a onclick="showLoginForm()">Sign In</a></p></div>
                </div>
                <div id="forgotModal" style="display: none;">
                    <div class="alert alert-info" style="display: block;">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Informasi Akun Default:</strong><br>
                        Username: <strong>admin</strong><br>
                        Password: <strong>admin123</strong><br><br>
                        <small>Silakan login dengan data di atas.</small>
                        <div class="mt-3"><button onclick="hideForgotPassword()" class="btn-signin" style="background: #6c757d; margin-top: 10px;">Kembali ke Login</button></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN APP -->
    <div id="appPage" style="display: none;">
        <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header"><i class="fas fa-chart-line"></i><h5>KeuanganKu Pro</h5><p id="userDisplay">User</p></div>
            <div class="sidebar-menu">
                <button onclick="showPage('dashboard')" id="menuDashboard" class="active"><i class="fas fa-home"></i> Dashboard</button>
                <button onclick="showPage('transaksi')" id="menuTransaksi"><i class="fas fa-exchange-alt"></i> Transaksi</button>
                <button onclick="showPage('kategori')" id="menuKategori"><i class="fas fa-tags"></i> Kategori</button>
                <button onclick="showPage('tabungan')" id="menuTabungan"><i class="fas fa-piggy-bank"></i> Tabungan</button>
                <button onclick="showPage('hutang')" id="menuHutang"><i class="fas fa-hand-holding-usd"></i> Hutang/Piutang</button>
                <button onclick="showPage('laporan')" id="menuLaporan"><i class="fas fa-file-alt"></i> Laporan</button>
                <button onclick="showPage('tambah')" id="menuTambah"><i class="fas fa-plus-circle"></i> Tambah Data</button>
                <button onclick="showEditProfileModal()"><i class="fas fa-user-cog"></i> Ubah Profil</button>
                <hr><button onclick="logout()"><i class="fas fa-sign-out-alt"></i> Logout</button>
            </div>
        </div>
        <div class="content">
            <div class="header"><h3 id="pageTitle">Dashboard</h3><div class="date" id="currentDate"></div></div>
            <div id="messageArea" class="alert" style="display: none;"></div>
            
            <!-- DASHBOARD -->
            <div id="dashboardPage">
                <div class="d-flex justify-content-between mb-3 flex-wrap gap-2"><h4>Ringkasan Keuangan</h4><button onclick="showPage('tambah')" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Tambah Data</button></div>
                <div class="stat-row">
                    <div class="stat-card"><div class="stat-icon primary"><i class="fas fa-wallet"></i></div><div class="stat-info"><h6>Total Saldo</h6><h4 id="totalBalance">Rp 0</h4></div></div>
                    <div class="stat-card"><div class="stat-icon success"><i class="fas fa-arrow-up"></i></div><div class="stat-info"><h6>Pemasukan Bulan Ini</h6><h4 id="monthlyIncome">Rp 0</h4></div></div>
                    <div class="stat-card"><div class="stat-icon danger"><i class="fas fa-arrow-down"></i></div><div class="stat-info"><h6>Pengeluaran Bulan Ini</h6><h4 id="monthlyExpense">Rp 0</h4></div></div>
                    <div class="stat-card"><div class="stat-icon info"><i class="fas fa-chart-line"></i></div><div class="stat-info"><h6>Total Transaksi</h6><h4 id="totalTransactions">0</h4></div></div>
                </div>
                <div class="row">
                    <div class="col-md-8"><div class="card"><div class="card-header"><h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Grafik 7 Hari Terakhir</h5></div><div class="card-body"><div class="chart-container"><canvas id="chartDashboard"></canvas></div></div></div></div>
                    <div class="col-md-4"><div class="ringkasan-card"><div class="d-flex justify-content-between align-items-center mb-3"><i class="fas fa-chart-pie fa-2x"></i><span style="background:rgba(255,255,255,0.2);padding:5px 12px;border-radius:20px;font-size:11px;">Info Terkini</span></div>
                        <div class="ringkasan-item"><p><i class="fas fa-tags me-2"></i> TOTAL KATEGORI</p><h5 id="totalCategories">0</h5></div>
                        <div class="ringkasan-item"><p><i class="fas fa-piggy-bank me-2"></i> TOTAL TABUNGAN</p><h5 id="totalSavings">0</h5></div>
                        <div class="ringkasan-item"><p><i class="fas fa-hand-holding-usd me-2"></i> HUTANG AKTIF</p><h5 id="activeDebts">0</h5></div>
                        <div class="ringkasan-item"><p><i class="fas fa-coins me-2"></i> TOTAL ASET TABUNGAN</p><h5 id="totalSavingsAmount">Rp 0</h5></div>
                    </div></div>
                </div>
                <div class="card"><div class="card-header"><h5 class="mb-0"><i class="fas fa-history me-2"></i>Transaksi Terbaru</h5></div><div class="card-body"><div class="table-responsive"><table class="table"><thead><tr><th>Tanggal</th><th>Kategori</th><th>Deskripsi</th><th>Jumlah</th><th>Tipe</th></tr></thead><tbody id="recentTransactions"></tbody></table></div></div></div>
            </div>
            
            <!-- TRANSAKSI -->
            <div id="transaksiPage" style="display: none;">
                <div class="d-flex justify-content-between mb-3 flex-wrap gap-2"><h4>Semua Transaksi</h4><div class="d-flex gap-2"><button onclick="showPage('tambah')" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Tambah</button><button onclick="showExportModal()" class="btn btn-success"><i class="fas fa-download me-1"></i>Export</button></div></div>
                <div class="card"><div class="card-body"><div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Tanggal</th><th>Kategori</th><th>Deskripsi</th><th>Jumlah</th><th>Tipe</th><th>Aksi</th></tr></thead><tbody id="allTransactions"></tbody></table></div></div></div>
            </div>
            
            <!-- KATEGORI -->
            <div id="kategoriPage" style="display: none;"><div class="d-flex justify-content-between mb-3"><h4>Manajemen Kategori</h4><button onclick="showPage('tambah')" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Tambah Kategori</button></div>
