    <script>
        // ========== USER AUTHENTICATION ==========
        let users = [];
        try {
            let stored = localStorage.getItem('users');
            if (stored) users = JSON.parse(stored);
            if (!users.find(u => u.username === 'admin')) {
                users.unshift({ username: 'admin', password: 'admin123', email: 'admin@keuangan.com' });
                localStorage.setItem('users', JSON.stringify(users));
            }
        } catch(e) { users = [{ username: 'admin', password: 'admin123' }]; localStorage.setItem('users', JSON.stringify(users)); }
        
        let currentUser = null;
        let transactions = [];
        let categories = [
            { id: 1, nama: 'Gaji', tipe: 'Pemasukan', warna: '#28a745', icon: 'fas fa-money-bill-wave' },
            { id: 2, nama: 'Bonus', tipe: 'Pemasukan', warna: '#17a2b8', icon: 'fas fa-gift' },
            { id: 3, nama: 'Makanan', tipe: 'Pengeluaran', warna: '#dc3545', icon: 'fas fa-utensils' },
            { id: 4, nama: 'Transport', tipe: 'Pengeluaran', warna: '#fd7e14', icon: 'fas fa-bus' },
            { id: 5, nama: 'Belanja', tipe: 'Pengeluaran', warna: '#6f42c1', icon: 'fas fa-shopping-cart' },
            { id: 6, nama: 'Tagihan', tipe: 'Pengeluaran', warna: '#20c997', icon: 'fas fa-file-invoice' },
            { id: 7, nama: 'Hiburan', tipe: 'Pengeluaran', warna: '#e83e8c', icon: 'fas fa-film' }
        ];
        let savings = [];
        let debts = [];
        let chart, monthlyChart;
        
        // ========== HELPER ==========
        function rupiah(angka) { return 'Rp ' + (angka || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }
        function formatTanggal(tanggal) { if(!tanggal) return '-'; let d=new Date(tanggal); return d.getDate()+' '+['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][d.getMonth()]+' '+d.getFullYear(); }
        
        function loadUserData(username) {
            try {
                transactions = JSON.parse(localStorage.getItem(`transactions_${username}`)) || [];
                let savedCats = localStorage.getItem(`categories_${username}`);
                if (savedCats) categories = JSON.parse(savedCats);
                savings = JSON.parse(localStorage.getItem(`savings_${username}`)) || [];
                debts = JSON.parse(localStorage.getItem(`debts_${username}`)) || [];
            } catch(e) {}
        }
        
        function saveUserData(username) {
            localStorage.setItem(`transactions_${username}`, JSON.stringify(transactions));
            localStorage.setItem(`categories_${username}`, JSON.stringify(categories));
            localStorage.setItem(`savings_${username}`, JSON.stringify(savings));
            localStorage.setItem(`debts_${username}`, JSON.stringify(debts));
        }
        
        // ========== LOGIN FUNCTIONS ==========
        function saveRememberMe(username, password) {
            try { localStorage.setItem('rememberedUser', JSON.stringify({ username, password, timestamp: Date.now() })); } catch(e) {}
        }
        function clearRememberMe() { try { localStorage.removeItem('rememberedUser'); } catch(e) {} }
        function getRememberedUser() {
            try { let r = localStorage.getItem('rememberedUser'); return r ? JSON.parse(r) : null; } catch(e) { return null; }
        }
        
        function showLoginForm() {
            document.getElementById('loginFormDiv').style.display = 'block';
            document.getElementById('registerFormDiv').style.display = 'none';
            document.getElementById('forgotModal').style.display = 'none';
            document.getElementById('loginError').style.display = 'none';
        }
        function showRegisterForm() {
            document.getElementById('loginFormDiv').style.display = 'none';
            document.getElementById('registerFormDiv').style.display = 'block';
            document.getElementById('forgotModal').style.display = 'none';
            document.getElementById('registerError').style.display = 'none';
            document.getElementById('registerSuccess').style.display = 'none';
        }
        function showForgotPassword() {
            document.getElementById('loginFormDiv').style.display = 'none';
            document.getElementById('registerFormDiv').style.display = 'none';
            document.getElementById('forgotModal').style.display = 'block';
        }
        function hideForgotPassword() { showLoginForm(); }
        
        function registerUser() {
            let username = document.getElementById('regUsername').value.trim();
            let email = document.getElementById('regEmail').value.trim();
            let password = document.getElementById('regPassword').value;
            let confirm = document.getElementById('regConfirmPassword').value;
            if (!username || !email || !password) { document.getElementById('registerError').innerHTML = 'Semua field harus diisi!'; document.getElementById('registerError').style.display = 'block'; return; }
            if (password !== confirm) { document.getElementById('registerError').innerHTML = 'Password tidak cocok!'; document.getElementById('registerError').style.display = 'block'; return; }
            if (users.find(u => u.username === username)) { document.getElementById('registerError').innerHTML = 'Username sudah terdaftar!'; document.getElementById('registerError').style.display = 'block'; return; }
            users.push({ username, password, email });
            localStorage.setItem('users', JSON.stringify(users));
            document.getElementById('registerError').style.display = 'none';
            document.getElementById('registerSuccess').innerHTML = 'Registrasi berhasil! Silakan login.';
            document.getElementById('registerSuccess').style.display = 'block';
            setTimeout(() => showLoginForm(), 1500);
        }
        
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            let username = document.getElementById('username').value.trim();
            let password = document.getElementById('password').value;
            let remember = document.getElementById('rememberMe').checked;
            if (!username || !password) { document.getElementById('loginError').innerHTML = 'Username dan password harus diisi!'; document.getElementById('loginError').style.display = 'block'; return; }
            users = JSON.parse(localStorage.getItem('users')) || [];
            if (!users.find(u => u.username === 'admin')) users.unshift({ username: 'admin', password: 'admin123' });
            let user = users.find(u => u.username === username && u.password === password);
            if (user) {
                if (remember) saveRememberMe(username, password); else clearRememberMe();
                currentUser = username;
                loadUserData(username);
                document.getElementById('loginPage').style.display = 'none';
                document.getElementById('appPage').style.display = 'block';
                document.getElementById('userDisplay').innerHTML = username;
                document.getElementById('currentDate').innerHTML = new Date().toLocaleDateString('id-ID', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
                refreshAllData();
                showPage('dashboard');
            } else {
                document.getElementById('loginError').innerHTML = 'Username atau password salah!<br><small>Default: admin / admin123</small>';
                document.getElementById('loginError').style.display = 'block';
            }
        });
        
        function logout() {
            if (currentUser) saveUserData(currentUser);
            currentUser = null;
            document.getElementById('loginPage').style.display = 'flex';
            document.getElementById('appPage').style.display = 'none';
            showLoginForm();
            document.getElementById('username').value = '';
            document.getElementById('password').value = '';
            document.getElementById('rememberMe').checked = false;
            if(window.innerWidth <= 768) closeSidebar();
        }
        
        // CEK REMEMBER ME
        function applyRememberedUser() {
            let remembered = getRememberedUser();
            if (remembered) {
                document.getElementById('username').value = remembered.username;
                document.getElementById('password').value = remembered.password;
                document.getElementById('rememberMe').checked = true;
                setTimeout(() => { document.getElementById('loginForm').dispatchEvent(new Event('submit')); }, 200);
            }
        }
        
        // ========== APP FUNCTIONS ==========
        function toggleSidebar() {
            let sidebar = document.getElementById('sidebar');
            let overlay = document.getElementById('sidebarOverlay');
            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            } else {
                sidebar.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }
        function showMessage(text, type) { let msg = document.getElementById('messageArea'); msg.className = 'alert alert-' + type; msg.innerHTML = text; msg.style.display = 'block'; setTimeout(() => msg.style.display = 'none', 3000); }
        
        function showPage(page) {
            document.getElementById('dashboardPage').style.display = 'none';
            document.getElementById('transaksiPage').style.display = 'none';
            document.getElementById('kategoriPage').style.display = 'none';
            document.getElementById('tabunganPage').style.display = 'none';
            document.getElementById('hutangPage').style.display = 'none';
            document.getElementById('laporanPage').style.display = 'none';
            document.getElementById('tambahPage').style.display = 'none';
            document.getElementById(page+'Page').style.display = 'block';
            document.getElementById('pageTitle').innerHTML = page.charAt(0).toUpperCase() + page.slice(1);
            document.querySelectorAll('.sidebar-menu button').forEach(btn => btn.classList.remove('active'));
            let menuBtn = document.getElementById('menu' + page.charAt(0).toUpperCase() + page.slice(1));
            if(menuBtn) menuBtn.classList.add('active');
            if(window.innerWidth <= 768) closeSidebar();
            if(page === 'dashboard') { updateDashboard(); setTimeout(() => updateChart(), 100); }
            if(page === 'transaksi') { displayAllTransactions(); updateCSVPreview(); }
            if(page === 'kategori') displayCategories();
            if(page === 'tabungan') displaySavings();
            if(page === 'hutang') displayDebts();
            if(page === 'laporan') { generateReport(); updateMonthlyComparisonChart(); }
            if(page === 'tambah') { updateTransactionKategori(); }
        }
        
        function refreshAllData() { updateDashboard(); displayAllTransactions(); displayCategories(); displaySavings(); displayDebts(); setTimeout(() => updateChart(), 100); if(currentUser) saveUserData(currentUser); }
        
        // DASHBOARD
        function updateDashboard() {
            let totalMasuk = transactions.filter(t=>t.tipe==='Pemasukan').reduce((s,t)=>s+(t.jumlah||0),0);
            let totalKeluar = transactions.filter(t=>t.tipe==='Pengeluaran').reduce((s,t)=>s+(t.jumlah||0),0);
            let now = new Date(), bulanIni = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0');
            let masukBulan = transactions.filter(t=>t.tanggal?.startsWith(bulanIni) && t.tipe==='Pemasukan').reduce((s,t)=>s+(t.jumlah||0),0);
            let keluarBulan = transactions.filter(t=>t.tanggal?.startsWith(bulanIni) && t.tipe==='Pengeluaran').reduce((s,t)=>s+(t.jumlah||0),0);
            document.getElementById('totalBalance').innerHTML = rupiah(totalMasuk - totalKeluar);
            document.getElementById('monthlyIncome').innerHTML = rupiah(masukBulan);
            document.getElementById('monthlyExpense').innerHTML = rupiah(keluarBulan);
            document.getElementById('totalTransactions').innerHTML = transactions.length;
            document.getElementById('totalCategories').innerHTML = categories.length;
            document.getElementById('totalSavings').innerHTML = savings.length;
            document.getElementById('activeDebts').innerHTML = debts.filter(d=>d.status !== 'Lunas').length;
            document.getElementById('totalSavingsAmount').innerHTML = rupiah(savings.reduce((s,sv)=>s+(sv.current||0),0));
            let recent = [...transactions].reverse().slice(0,5);
            document.getElementById('recentTransactions').innerHTML = recent.map(t => `<tr><td>${formatTanggal(t.tanggal)}</td><td>${t.kategori||'-'}</td><td>${t.deskripsi||'-'}</td><td class="${t.tipe==='Pemasukan'?'text-success':'text-danger'} fw-bold">${rupiah(t.jumlah)}</td><td><span class="badge ${t.tipe==='Pemasukan'?'badge-success':'badge-danger'}">${t.tipe}</span></td></tr>`).join('') || '<tr><td colspan="5" class="text-center">Belum ada transaksi</td></tr>';
        }
        
        function updateChart() {
            let ctx = document.getElementById('chartDashboard')?.getContext('2d'); if(!ctx) return;
            if(chart) chart.destroy();
            let labels=[], pMasuk=[], pKeluar=[];
            for(let i=6;i>=0;i--){ let d=new Date(); d.setDate(d.getDate()-i); let ds=d.toISOString().split('T')[0]; labels.push(d.getDate()+'/'+(d.getMonth()+1));
                let dayTrans=transactions.filter(t=>t.tanggal===ds);
                pMasuk.push(dayTrans.filter(t=>t.tipe==='Pemasukan').reduce((s,t)=>s+(t.jumlah||0),0));
                pKeluar.push(dayTrans.filter(t=>t.tipe==='Pengeluaran').reduce((s,t)=>s+(t.jumlah||0),0));
            }
            chart = new Chart(ctx,{type:'line',data:{labels,datasets:[{label:'Pemasukan',data:pMasuk,borderColor:'#28a745',backgroundColor:'rgba(40,167,69,0.1)',fill:true,tension:0.3},{label:'Pengeluaran',data:pKeluar,borderColor:'#dc3545',backgroundColor:'rgba(220,53,69,0.1)',fill:true,tension:0.3}]},options:{responsive:true,maintainAspectRatio:false,scales:{y:{ticks:{callback:v=>'Rp '+v.toLocaleString('id-ID')}}}}});
        }
        
        function updateMonthlyComparisonChart() {
            let ctx = document.getElementById('monthlyComparisonChart')?.getContext('2d'); if(!ctx) return;
            if(monthlyChart) monthlyChart.destroy();
            let months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
            let tahun = document.getElementById('reportYear').value;
            let pMasuk=[], pKeluar=[];
            for(let m=1;m<=12;m++){ let bulanStr=`${tahun}-${String(m).padStart(2,'0')}`;
                pMasuk.push(transactions.filter(t=>t.tanggal?.startsWith(bulanStr) && t.tipe==='Pemasukan').reduce((s,t)=>s+(t.jumlah||0),0));
                pKeluar.push(transactions.filter(t=>t.tanggal?.startsWith(bulanStr) && t.tipe==='Pengeluaran').reduce((s,t)=>s+(t.jumlah||0),0));
            }
            monthlyChart = new Chart(ctx,{type:'bar',data:{labels:months,datasets:[{label:'Pemasukan',data:pMasuk,backgroundColor:'#28a745'},{label:'Pengeluaran',data:pKeluar,backgroundColor:'#dc3545'}]},options:{responsive:true,maintainAspectRatio:false,scales:{y:{ticks:{callback:v=>'Rp '+v.toLocaleString('id-ID')}}}}});
        }
        
        // TRANSAKSI
        function displayAllTransactions() {
            let html = '';
            [...transactions].reverse().forEach((t,i)=>{
                let cat = categories.find(c=>c.nama===t.kategori)||{warna:'#6c757d'};
                html += `<tr><td>${formatTanggal(t.tanggal)}</td><td><span style="display:inline-block;width:12px;height:12px;border-radius:4px;background:${cat.warna};margin-right:5px;"></span>${t.kategori}</td><td>${t.deskripsi||'-'}</td><td class="${t.tipe==='Pemasukan'?'text-success':'text-danger'} fw-bold">${rupiah(t.jumlah)}</td><td><span class="badge ${t.tipe==='Pemasukan'?'badge-success':'badge-danger'}">${t.tipe}</span></td><td><button onclick="deleteTransaction(${i})" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Hapus</button></td></tr>`;
            });
            document.getElementById('allTransactions').innerHTML = html || '<tr><td colspan="6" class="text-center">Belum ada transaksi</td></tr>';
        }
        function deleteTransaction(i) { if(confirm('Hapus transaksi?')){ transactions.splice(i,1); refreshAllData(); showMessage('Transaksi dihapus','success'); } }
        function saveTransaction(){
            let tipe=document.getElementById('transactionTipe').value, kategori=document.getElementById('transactionKategori').value, jumlah=parseInt(document.getElementById('transactionJumlah').value), deskripsi=document.getElementById('transactionDeskripsi').value, tanggal=document.getElementById('transactionTanggal').value || new Date().toISOString().split('T')[0];
            if(!jumlah || jumlah<=0) return showMessage('Jumlah harus positif','danger');
            transactions.push({id:Date.now(), tanggal, tipe, kategori, jumlah, deskripsi});
            refreshAllData();
            showMessage('Transaksi ditambahkan','success');
            document.getElementById('transactionJumlah').value='';
            document.getElementById('transactionDeskripsi').value='';
        }
        function updateTransactionKategori(){
            let tipe=document.getElementById('transactionTipe').value;
            document.getElementById('transactionKategori').innerHTML = categories.filter(c=>c.tipe===tipe).map(c=>`<option value="${c.nama}">${c.nama}</option>`).join('');
        }
        
        // KATEGORI
        function displayCategories(){
            document.getElementById('incomeCategoriesList').innerHTML = categories.filter(c=>c.tipe==='Pemasukan').map(c=>`<div class="category-item"><div><span class="category-badge" style="background:${c.warna}"></span><i class="${c.icon} me-1"></i><strong>${c.nama}</strong></div><div><button onclick="editCategory(${c.id})" class="btn btn-warning btn-sm me-1"><i class="fas fa-edit"></i></button><button onclick="deleteCategory(${c.id})" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button></div></div>`).join('') || '<p class="text-muted text-center">Belum ada kategori</p>';
            document.getElementById('expenseCategoriesList').innerHTML = categories.filter(c=>c.tipe==='Pengeluaran').map(c=>`<div class="category-item"><div><span class="category-badge" style="background:${c.warna}"></span><i class="${c.icon} me-1"></i><strong>${c.nama}</strong></div><div><button onclick="editCategory(${c.id})" class="btn btn-warning btn-sm me-1"><i class="fas fa-edit"></i></button><button onclick="deleteCategory(${c.id})" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button></div></div>`).join('') || '<p class="text-muted text-center">Belum ada kategori</p>';
        }
        function saveCategory(){ let nama=document.getElementById('categoryName').value.trim(), tipe=document.getElementById('categoryType').value, warna=document.getElementById('categoryColor').value, icon=document.getElementById('categoryIcon').value; if(!nama) return showMessage('Nama kategori harus diisi','danger'); categories.push({id:Date.now(), nama, tipe, warna, icon}); refreshAllData(); showMessage('Kategori ditambahkan','success'); document.getElementById('categoryName').value=''; }
        function editCategory(id){ let c=categories.find(c=>c.id===id); if(c){ document.getElementById('editCategoryId').value=c.id; document.getElementById('editCategoryName').value=c.nama; document.getElementById('editCategoryType').value=c.tipe; document.getElementById('editCategoryColor').value=c.warna; document.getElementById('editCategoryIcon').value=c.icon; document.getElementById('editCategoryModal').style.display='flex'; } }
        function closeEditCategoryModal(){ document.getElementById('editCategoryModal').style.display='none'; }
        function updateCategory(){ let id=parseInt(document.getElementById('editCategoryId').value), idx=categories.findIndex(c=>c.id===id); if(idx!==-1){ categories[idx]={id, nama:document.getElementById('editCategoryName').value, tipe:document.getElementById('editCategoryType').value, warna:document.getElementById('editCategoryColor').value, icon:document.getElementById('editCategoryIcon').value}; refreshAllData(); closeEditCategoryModal(); showMessage('Kategori diupdate','success'); } }
        function deleteCategory(id){ if(confirm('Hapus kategori?')){ categories=categories.filter(c=>c.id!==id); refreshAllData(); showMessage('Kategori dihapus','success'); } }
        
        // TABUNGAN
        function displaySavings(){
            if(savings.length===0){ document.getElementById('savingsList').innerHTML='<div class="col-12"><div class="card p-4 text-center"><i class="fas fa-piggy-bank fa-3x text-muted mb-2"></i><h5>Belum ada tabungan</h5><button onclick="showPage(\'tambah\')" class="btn btn-primary mt-2">Tambah Tabungan</button></div></div>'; return; }
            let html='';
            savings.forEach(s=>{ let persen=s.target?Math.min(100,Math.round((s.current/s.target)*100)):0; html+=`<div class="col-md-6 mb-3"><div class="card"><div class="card-body"><div class="d-flex justify-content-between"><h5>${s.nama}</h5><div><button onclick='openAddSavingModal(${s.id},"${s.nama}")' class="btn btn-success btn-sm me-1"><i class="fas fa-plus"></i></button><button onclick="deleteSaving(${s.id})" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button></div></div><div class="progress mb-2"><div class="progress-bar" style="width:${persen}%">${persen}%</div></div><div class="d-flex justify-content-between"><span>Terkumpul: ${rupiah(s.current)}</span><span>Target: ${rupiah(s.target)}</span></div>${s.deadline?`<p class="text-muted small mt-2"><i class="far fa-calendar-alt"></i> Deadline: ${formatTanggal(s.deadline)}</p>`:''}</div></div></div>`; });
            document.getElementById('savingsList').innerHTML = html;
        }
        function saveSaving(){ let nama=document.getElementById('savingName').value.trim(), target=parseInt(document.getElementById('savingTarget').value), current=parseInt(document.getElementById('savingCurrent').value)||0, deadline=document.getElementById('savingDeadline').value; if(!nama||!target) return showMessage('Nama dan target harus diisi','danger'); savings.push({id:Date.now(), nama, target, current, deadline:deadline||null}); refreshAllData(); showMessage('Tabungan ditambahkan','success'); document.getElementById('savingName').value=''; document.getElementById('savingTarget').value=''; document.getElementById('savingCurrent').value='0'; document.getElementById('savingDeadline').value=''; }
        function openAddSavingModal(id,nama){ document.getElementById('addSavingId').value=id; document.getElementById('addSavingName').innerHTML=nama; document.getElementById('addSavingAmount').value=''; document.getElementById('addSavingModal').style.display='flex'; }
        function closeAddSavingModal(){ document.getElementById('addSavingModal').style.display='none'; }
        function processAddSaving(){ let id=parseInt(document.getElementById('addSavingId').value), amount=parseInt(document.getElementById('addSavingAmount').value); if(!amount||amount<=0) return showMessage('Jumlah valid diperlukan','danger'); let idx=savings.findIndex(s=>s.id===id); if(idx!==-1){ savings[idx].current=(savings[idx].current||0)+amount; refreshAllData(); closeAddSavingModal(); showMessage('Saldo ditambahkan','success'); } }
        function deleteSaving(id){ if(confirm('Hapus tabungan?')){ savings=savings.filter(s=>s.id!==id); refreshAllData(); showMessage('Tabungan dihapus','success'); } }
        
        // HUTANG
        function displayDebts(){
            let hutang='', piutang='';
            debts.forEach((d,i)=>{ if(d.status!=='Lunas'){ if(d.tipe==='Hutang'){ hutang+=`<div class="border-bottom mb-2 pb-2"><div class="d-flex justify-content-between"><div><strong>${d.nama}</strong><br><small>${d.deskripsi||'-'}</small></div><div class="text-end"><span class="text-danger fw-bold">${rupiah(d.jumlah)}</span><br><button onclick="lunasHutang(${i})" class="btn btn-success btn-sm mt-1">Lunas</button></div></div></div>`; } else { piutang+=`<div class="border-bottom mb-2 pb-2"><div class="d-flex justify-content-between"><div><strong>${d.nama}</strong><br><small>${d.deskripsi||'-'}</small></div><div class="text-end"><span class="text-success fw-bold">${rupiah(d.jumlah)}</span><br><button onclick="lunasHutang(${i})" class="btn btn-success btn-sm mt-1">Diterima</button></div></div></div>`; } } });
            document.getElementById('debtsList').innerHTML = hutang || '<p class="text-muted text-center">Tidak ada hutang</p>';
            document.getElementById('receivablesList').innerHTML = piutang || '<p class="text-muted text-center">Tidak ada piutang</p>';
        }
        function lunasHutang(i){ debts[i].status='Lunas'; refreshAllData(); showMessage('Status diperbarui','success'); }
        function saveDebt(){ let tipe=document.getElementById('debtTipe').value, nama=document.getElementById('debtNama').value.trim(), jumlah=parseInt(document.getElementById('debtJumlah').value), deskripsi=document.getElementById('debtDeskripsi').value, tanggal=document.getElementById('debtTanggal').value||new Date().toISOString().split('T')[0], jatuhTempo=document.getElementById('debtJatuhTempo').value; if(!nama||!jumlah) return showMessage('Nama dan jumlah harus diisi','danger'); debts.push({id:Date.now(), tipe, nama, jumlah, deskripsi, tanggal, jatuhTempo, status:'Belum Lunas'}); refreshAllData(); showMessage('Data ditambahkan','success'); document.getElementById('debtNama').value=''; document.getElementById('debtJumlah').value=''; document.getElementById('debtDeskripsi').value=''; document.getElementById('debtJatuhTempo').value=''; }
        
        // LAPORAN
        function generateReport(){
            let bulan=document.getElementById('reportMonth').value.padStart(2,'0'), tahun=document.getElementById('reportYear').value, bulanStr=`${tahun}-${bulan}`;
            let filtered=transactions.filter(t=>t.tanggal?.startsWith(bulanStr));
            let totalMasuk=filtered.filter(t=>t.tipe==='Pemasukan').reduce((s,t)=>s+(t.jumlah||0),0);
            let totalKeluar=filtered.filter(t=>t.tipe==='Pengeluaran').reduce((s,t)=>s+(t.jumlah||0),0);
            document.getElementById('reportIncome').innerHTML=rupiah(totalMasuk);
            document.getElementById('reportExpense').innerHTML=rupiah(totalKeluar);
            document.getElementById('reportBalance').innerHTML=rupiah(totalMasuk-totalKeluar);
            document.getElementById('reportTransactions').innerHTML=filtered.map(t=>`<tr><td>${formatTanggal(t.tanggal)}</td><td>${t.kategori}</td><td>${t.deskripsi||'-'}</td><td class="text-end fw-bold ${t.tipe==='Pemasukan'?'text-success':'text-danger'}">${rupiah(t.jumlah)}</td><td class="text-center"><span class="badge ${t.tipe==='Pemasukan'?'badge-success':'badge-danger'}">${t.tipe}</span></td></tr>`).join('')||'<td><td colspan="5" class="text-center">Tidak ada transaksi</td></tr>';
            updateMonthlyComparisonChart();
        }
        function exportMonthlyReport(){
            let bulan=document.getElementById('reportMonth').value.padStart(2,'0'), tahun=document.getElementById('reportYear').value;
            let data=transactions.filter(t=>t.tanggal?.startsWith(`${tahun}-${bulan}`));
            let csv="Tanggal,Tipe,Kategori,Deskripsi,Jumlah\n"+data.map(t=>`"${t.tanggal}","${t.tipe}","${t.kategori}","${(t.deskripsi||'').replace(/"/g,'""')}","${t.jumlah}"`).join("\n");
            let blob=new Blob(["\uFEFF"+csv],{type:'text/csv'});
            let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`laporan_${tahun}_${bulan}.csv`; a.click(); URL.revokeObjectURL(a.href);
            showMessage('Laporan diekspor','success');
        }
        
        // EXPORT
        function showExportModal(){ updateCSVPreview(); document.getElementById('exportModal').style.display='flex'; }
        function closeExportModal(){ document.getElementById('exportModal').style.display='none'; }
        function updateCSVPreview(){
            let tbody=document.getElementById('csvPreviewBody');
            if(!tbody) return;
            let preview=[...transactions].reverse().slice(0,10);
            if(preview.length===0){ tbody.innerHTML='<tr><td colspan="5" style="text-align:center">Belum ada transaksi</td></tr>'; return; }
            tbody.innerHTML=preview.map(t=>`<tr><td>${formatTanggal(t.tanggal)}</td><td><span class="badge ${t.tipe==='Pemasukan'?'badge-success':'badge-danger'}">${t.tipe}</span></td><td>${t.kategori}</td><td>${t.deskripsi||'-'}</td><td>${rupiah(t.jumlah)}</td></tr>`).join('');
        }
        function exportData(format){
            let data=transactions;
            let filename=`transaksi_${Date.now()}`;
            if(format==='json'){ let blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'}); let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`${filename}.json`; a.click(); URL.revokeObjectURL(a.href); showMessage('JSON diekspor','success'); }
            else if(format==='csv'){ let headers="Tanggal,Tipe,Kategori,Deskripsi,Jumlah"; let rows=data.map(t=>`"${t.tanggal}","${t.tipe}","${t.kategori}","${(t.deskripsi||'').replace(/"/g,'""')}","${t.jumlah}"`).join("\n"); let blob=new Blob(["\uFEFF"+headers+"\n"+rows],{type:'text/csv'}); let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=`${filename}.csv`; a.click(); URL.revokeObjectURL(a.href); showMessage('CSV diekspor','success'); }
            closeExportModal();
        }
        
        // EDIT PROFIL
        function showEditProfileModal(){ document.getElementById('newUsername').value=currentUser; document.getElementById('oldPassword').value=''; document.getElementById('newPassword').value=''; document.getElementById('confirmNewPassword').value=''; document.getElementById('profileError').style.display='none'; document.getElementById('profileSuccess').style.display='none'; document.getElementById('editProfileModal').style.display='flex'; }
        function closeEditProfileModal(){ document.getElementById('editProfileModal').style.display='none'; }
        function updateProfile(){
            let newUsername=document.getElementById('newUsername').value.trim(), oldPassword=document.getElementById('oldPassword').value, newPassword=document.getElementById('newPassword').value, confirm=document.getElementById('confirmNewPassword').value;
            let idx=users.findIndex(u=>u.username===currentUser);
            if(idx===-1){ showMessage('User tidak ditemukan','danger'); return; }
            if(users[idx].password!==oldPassword){ document.getElementById('profileError').innerHTML='Password lama salah!'; document.getElementById('profileError').style.display='block'; return; }
            if(newUsername!==currentUser && users.find(u=>u.username===newUsername)){ document.getElementById('profileError').innerHTML='Username sudah digunakan!'; document.getElementById('profileError').style.display='block'; return; }
            if(newPassword && newPassword!==confirm){ document.getElementById('profileError').innerHTML='Password baru tidak cocok!'; document.getElementById('profileError').style.display='block'; return; }
            saveUserData(currentUser);
            if(newUsername!==currentUser){
                localStorage.setItem(`transactions_${newUsername}`,JSON.stringify(transactions));
                localStorage.setItem(`categories_${newUsername}`,JSON.stringify(categories));
                localStorage.setItem(`savings_${newUsername}`,JSON.stringify(savings));
                localStorage.setItem(`debts_${newUsername}`,JSON.stringify(debts));
                localStorage.removeItem(`transactions_${currentUser}`);
                localStorage.removeItem(`categories_${currentUser}`);
                localStorage.removeItem(`savings_${currentUser}`);
                localStorage.removeItem(`debts_${currentUser}`);
            }
            users[idx]={username:newUsername, password:newPassword||oldPassword};
            localStorage.setItem('users',JSON.stringify(users));
            if(getRememberedUser() && getRememberedUser().username===currentUser) saveRememberMe(newUsername,newPassword||oldPassword);
            currentUser=newUsername;
            document.getElementById('userDisplay').innerHTML=currentUser;
            document.getElementById('profileSuccess').innerHTML='Profil diupdate! Silakan login ulang.';
            document.getElementById('profileSuccess').style.display='block';
            setTimeout(()=>{ closeEditProfileModal(); logout(); },2000);
        }
        
        function openTab(tabId){
            document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.target.closest('.tab-btn').classList.add('active');
        }
        
        // INIT
        document.getElementById('transactionTanggal').value = new Date().toISOString().split('T')[0];
        document.getElementById('debtTanggal').value = new Date().toISOString().split('T')[0];
        document.getElementById('menuToggle').addEventListener('click', toggleSidebar);
        document.getElementById('sidebarOverlay').addEventListener('click', closeSidebar);
        window.addEventListener('resize', function() { if(window.innerWidth > 768) closeSidebar(); });
        
        // APPLY REMEMBER ME
        applyRememberedUser();
        
        console.log('%c✅ APLIKASI KEUANGAN PRO - SIAP DIGUNAKAN', 'color: #28a745; font-size: 16px; font-weight: bold');
        console.log('%c🔐 Login: admin | Password: admin123', 'color: #ff9800; font-size: 14px');
    </script>
</body>
</html>
